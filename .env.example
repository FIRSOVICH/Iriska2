PORT=4000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iriska
DB_USER=postgres
DB_PASSWORD=ВАШ_ПАРОЛЬ

# Redis
REDIS_URL=redis://localhost:6379

# JWT (минимум 32 случайных символа — обязательно поменяй!)
JWT_SECRET=МИНИМУМ_32_СЛУЧАЙНЫХ_СИМВОЛА_ОБЯЗАТЕЛЬНО_ПОМЕНЯЙ
JWT_REFRESH_SECRET=ДРУГИЕ_32_СЛУЧАЙНЫХ_СИМВОЛА_ОБЯЗАТЕЛЬНО_ПОМЕНЯЙ
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Файлы
UPLOADS_DIR=./uploads
MAX_FILE_SIZE_MB=50

# CORS (домены через запятую)
ALLOWED_ORIGINS=http://localhost:5173

# VAPID (сгенерировать: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=push@твой-домен.ru
